generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String    @id @default(cuid())
  nameHe    String
  sortOrder Int       @default(0)
  products  Product[] @relation("ProductCategories")
}

model Product {
  id            String         @id @default(cuid())
  nameHe        String
  descriptionHe String         @default("")
  price         Float          @default(150)
  stock         Int            @default(0)
  image         String         @default("")
  active        Boolean        @default(true)
  categories    Category[]     @relation("ProductCategories")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orderItems    OrderItem[]
  images        ProductImage[]
  colors        ProductColor[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductColor {
  id         String              @id @default(cuid())
  productId  String
  nameHe     String
  hex        String              @default("#000000")
  stock      Int                 @default(0)
  sortOrder  Int                 @default(0)
  imageUrl   String?
  linkedUrl  String?
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductColorImage[]
  sizes      ProductColorSize[]
}

model ProductColorSize {
  id      String       @id @default(cuid())
  colorId String
  size    String
  stock   Int          @default(0)
  color   ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@unique([colorId, size])
}

model ProductColorImage {
  id        String       @id @default(cuid())
  colorId   String
  url       String
  sortOrder Int          @default(0)
  color     ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String
  address       String
  city          String
  items         OrderItem[]
  subtotal      Float
  delivery      Float       @default(40)
  total         Float
  status        String      @default("pending")
  paymentId     String?
  shipmentNumber String?
  shipmentRandId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  size      String
  color     String?
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model AdminPhone {
  id        String   @id @default(cuid())
  phone     String   @unique
  label     String?
  createdAt DateTime @default(now())
}

model AdminOtp {
  phone     String   @id
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SiteConfig {
  key   String @id
  value String
}

model Newsletter {
  id             String    @id @default(cuid())
  phone          String?   @unique
  email          String?
  couponCode     String    @unique
  usedAt         DateTime?
  reminderSentAt DateTime?
  createdAt      DateTime  @default(now())
}

model Promotion {
  id         String               @id @default(cuid())
  name       String
  active     Boolean              @default(true)
  createdAt  DateTime             @default(now())
  conditions PromotionCondition[]
  rewards    PromotionReward[]
}

model PromotionCondition {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  type        String    // "min_cart_total" | "product_in_cart"
  productId   String?
  minTotal    Float?
}

model PromotionReward {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  type        String    // "free_shipping" | "cart_discount" | "product_discount"
  productId   String?
  discountPct Int?
}

model Coupon {
  id           String    @id @default(cuid())
  code         String    @unique
  discountPct  Int       @default(5)
  singleUse    Boolean   @default(true)
  usedByEmail  String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  usedAt       DateTime?
}
